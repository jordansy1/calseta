# ============================================================
# Calseta — Local Development Configuration
# ============================================================
# Copy to .env for local development.
# These values are intentionally permissive for ease of development.
# Never use these values in production.
#
# For production hardened values, see .env.prod.example
# ============================================================

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/calseta

QUEUE_BACKEND=postgres
QUEUE_CONCURRENCY=5

# Fernet encryption key for at-rest secret storage.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave empty to skip encryption (enrichment provider secrets and agent auth headers won't work).
ENCRYPTION_KEY=

RATE_LIMIT_UNAUTHED_PER_MINUTE=300
RATE_LIMIT_AUTHED_PER_MINUTE=9999
RATE_LIMIT_INGEST_PER_MINUTE=9999
RATE_LIMIT_ENRICHMENT_PER_MINUTE=9999
RATE_LIMIT_WORKFLOW_EXECUTE_PER_MINUTE=9999

# Allow agent webhooks to host.docker.internal and localhost (dev only)
SSRF_ALLOWED_HOSTS=host.docker.internal,localhost,127.0.0.1

TRUSTED_PROXY_COUNT=0
HTTPS_ENABLED=false

# Disable CORS restrictions locally
CORS_ALLOW_ALL_ORIGINS=true

MAX_REQUEST_BODY_SIZE_MB=50
MAX_INGEST_PAYLOAD_SIZE_MB=50

# Human-readable logs for local development
LOG_LEVEL=DEBUG
LOG_FORMAT=text
APP_VERSION=dev

# Webhook secrets — leave empty locally; signature verification logs a warning but passes
SENTINEL_WEBHOOK_SECRET=
ELASTIC_WEBHOOK_SECRET=
SPLUNK_WEBHOOK_SECRET=

# Fill in real keys to test enrichment locally, or leave empty
# (enrichment providers are skipped when unconfigured, not errors)
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
OKTA_DOMAIN=
OKTA_API_TOKEN=
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=

# AI / LLM — needed for workflow code generation (optional)
ANTHROPIC_API_KEY=

# Base URLs — defaults work for local dev
# CALSETA_BASE_URL=http://localhost:8000
# CALSETA_API_BASE_URL=http://localhost:8000

# Approval Notifications — leave as "none" unless testing Slack/Teams locally
# See docs/guides/HOW_TO_SETUP_SLACK_APPROVALS.md or docs/guides/HOW_TO_SETUP_TEAMS_APPROVALS.md
APPROVAL_NOTIFIER=none
# APPROVAL_DEFAULT_TIMEOUT_SECONDS=3600
# APPROVAL_DEFAULT_CHANNEL=              # Slack channel ID (e.g. C0123456789)
# SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET=
# TEAMS_WEBHOOK_URL=

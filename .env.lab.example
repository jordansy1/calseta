# ============================================================
# Calseta — Lab Environment Configuration
# ============================================================
# Copy to .env to run the lab environment with `make lab`.
# Seeds 5 case study alerts with mock enrichment data.
# Full-access API key: cai_lab_demo_full_access_key_not_for_prod
# ============================================================

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/calseta

QUEUE_BACKEND=postgres
QUEUE_CONCURRENCY=5

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Lab mode — enables sandbox seeding + mock enrichment
SANDBOX_MODE=true
ENRICHMENT_MOCK_MODE=true

# Permissive rate limits for lab use
RATE_LIMIT_UNAUTHED_PER_MINUTE=300
RATE_LIMIT_AUTHED_PER_MINUTE=9999
RATE_LIMIT_INGEST_PER_MINUTE=9999
RATE_LIMIT_ENRICHMENT_PER_MINUTE=9999
RATE_LIMIT_WORKFLOW_EXECUTE_PER_MINUTE=9999

SSRF_ALLOWED_HOSTS=host.docker.internal,localhost,127.0.0.1

TRUSTED_PROXY_COUNT=0
HTTPS_ENABLED=false

CORS_ALLOW_ALL_ORIGINS=true

MAX_REQUEST_BODY_SIZE_MB=50
MAX_INGEST_PAYLOAD_SIZE_MB=50

LOG_LEVEL=DEBUG
LOG_FORMAT=text
APP_VERSION=dev

# Webhook secrets — empty for lab
SENTINEL_WEBHOOK_SECRET=
ELASTIC_WEBHOOK_SECRET=
SPLUNK_WEBHOOK_SECRET=

# Enrichment API keys — optional for lab (mock mode provides synthetic results)
# Fill in real keys to test live enrichment:
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
OKTA_DOMAIN=
OKTA_API_TOKEN=
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=

# AI / LLM — optional for lab
ANTHROPIC_API_KEY=

# Approval Notifications — leave as "none" for lab; set to "slack" or "teams" to test
APPROVAL_NOTIFIER=none
# APPROVAL_DEFAULT_CHANNEL=              # Slack channel ID (e.g. C0123456789)
# SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET=
# TEAMS_WEBHOOK_URL=
